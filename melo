#!/bin/bash

# melo - Structured UI Generator with Bolt + Codex refinement
# Usage: melo "your UI description" [file1 file2 ...]
# Example: melo "Create a dashboard card" src/utils/data.ts lib/api.ts

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMP_DIR="${TEMP_DIR:-./.melo-temp}"
OUTPUT_DIR="${OUTPUT_DIR:-./.melo-output}"
BOLT_TIMEOUT="${BOLT_TIMEOUT:-300}" # 5 minutes

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Logging functions
log_info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

log_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

log_error() {
    echo -e "${RED}❌ $1${NC}"
}

log_warn() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

# Setup
setup() {
    mkdir -p "$TEMP_DIR" "$OUTPUT_DIR"
    log_info "Working directory: $TEMP_DIR"
}

# Extract file paths from prompt
extract_file_paths() {
    local prompt="$1"
    local files=()
    
    # Look for common file patterns in the prompt
    # This is intentionally simple - Codex will mention specific files if needed
    echo "$prompt" | grep -oE '[a-zA-Z0-9._/-]+\.(ts|tsx|js|jsx|json|sql|md|env|yaml|yml)' || true
}

# Read referenced files to build context
build_project_context() {
    local prompt="$1"
    shift
    local files=("$@")
    
    log_info "Building project context..."
    
    local context=""
    context+="# PROJECT CONTEXT\n"
    context+="## Prompt\n$prompt\n\n"
    
    if [ ${#files[@]} -gt 0 ]; then
        context+="## Referenced Files\n"
        for file in "${files[@]}"; do
            if [ -f "$file" ]; then
                log_info "Reading: $file"
                context+="### $file\n"
                context+="\`\`\`\n"
                context+="$(cat "$file")\n"
                context+="\`\`\`\n\n"
            else
                log_warn "File not found: $file"
            fi
        done
    fi
    
    # Also check for common config files
    local config_files=("package.json" ".env.example" "tsconfig.json" "next.config.js" "tailwind.config.js")
    for cf in "${config_files[@]}"; do
        if [ -f "$cf" ] && [[ ! " ${files[@]} " =~ " ${cf} " ]]; then
            log_info "Including config: $cf"
            context+="### $cf\n"
            context+="\`\`\`\n"
            context+="$(cat "$cf")\n"
            context+="\`\`\`\n\n"
        fi
    done
    
    echo -e "$context"
}

# Call Bolt with prompt and context
call_bolt() {
    local prompt="$1"
    local context="$2"
    
    log_info "Generating UI with Bolt..."
    
    # Create a Bolt prompt file
    local bolt_prompt_file="$TEMP_DIR/bolt-prompt.txt"
    echo -e "$context" > "$bolt_prompt_file"
    
    # Generate Bolt share link prompt
    local bolt_message="Generate a React component for:\n\n$prompt\n\nWith this project context:\n\n$context"
    
    log_info "Bolt prompt created at: $bolt_prompt_file"
    log_warn "⚠️  Manual step: Visit https://bolt.new and paste the context"
    log_warn "Generated prompt saved to: $bolt_prompt_file"
    log_info "Once you download the code from Bolt, paste it here or run:"
    log_info "melo --import-bolt <bolt-code-file>"
    
    # Save for later import
    echo "$bolt_message" > "$TEMP_DIR/bolt-context.txt"
}

# Import downloaded Bolt code
import_bolt_code() {
    local code_file="$1"
    
    if [ ! -f "$code_file" ]; then
        log_error "File not found: $code_file"
        return 1
    fi
    
    log_success "Imported Bolt code from: $code_file"
    cp "$code_file" "$TEMP_DIR/bolt-generated.tsx"
    
    echo "$TEMP_DIR/bolt-generated.tsx"
}

# Call Codex to refine with project context
refine_with_codex() {
    local bolt_code="$1"
    local project_context="$2"
    local original_prompt="$3"
    
    log_info "Refining with Codex..."
    
    # Create refinement prompt
    local refinement_prompt="$TEMP_DIR/refinement-prompt.txt"
    cat > "$refinement_prompt" << 'EOF'
You are refining a UI component generated by Bolt. Your job is to:

1. Take the Bolt-generated code and add backend structure
2. Connect it to the existing project
3. Add error handling, types, and validation
4. Make it production-ready
5. Use the project context to make smart decisions

BOLT GENERATED CODE:
---
EOF
    
    cat "$bolt_code" >> "$refinement_prompt"
    
    cat >> "$refinement_prompt" << 'EOF'

PROJECT CONTEXT:
---
EOF
    
    echo "$project_context" >> "$refinement_prompt"
    
    cat >> "$refinement_prompt" << 'EOF'

ORIGINAL REQUEST:
---
EOF
    
    echo "$original_prompt" >> "$refinement_prompt"
    
    log_info "Refinement prompt saved to: $refinement_prompt"
    log_info "Now calling Codex to refine this component with project awareness..."
    
    # Call codex with the refinement prompt
    if command -v codex &> /dev/null; then
        log_info "Calling Codex CLI..."
        local refined_output="$TEMP_DIR/refined-component.tsx"
        codex "$(cat "$refinement_prompt")" > "$refined_output" 2>/dev/null || true
        
        if [ -s "$refined_output" ]; then
            log_success "Codex refinement complete"
            echo "$refined_output"
        else
            log_warn "Codex CLI output empty, returning Bolt code as-is"
            echo "$bolt_code"
        fi
    else
        log_warn "Codex CLI not found, returning Bolt code"
        log_info "To use Codex refinement, install: https://github.com/openai/codex-cli"
        echo "$bolt_code"
    fi
}

# Save final component
save_component() {
    local component_code="$1"
    local component_name="${2:-GeneratedComponent}"
    
    local output_file="$OUTPUT_DIR/${component_name}.tsx"
    cp "$component_code" "$output_file"
    
    log_success "Component saved to: $output_file"
    
    # Show the component
    log_info "Generated component:"
    echo "---"
    cat "$output_file"
    echo "---"
    
    echo "$output_file"
}

# Cleanup
cleanup() {
    if [ "${KEEP_TEMP:-0}" != "1" ]; then
        log_info "Cleaning up temporary files..."
        rm -rf "$TEMP_DIR"
    else
        log_info "Keeping temp files at: $TEMP_DIR"
    fi
}

# Main flow
main() {
    if [ $# -lt 1 ]; then
        echo "Usage: melo \"Your UI description\" [file1 file2 ...]"
        echo ""
        echo "Examples:"
        echo "  melo \"Create a login form\" src/auth.ts lib/api.ts"
        echo "  melo \"Dashboard card for stats\""
        echo ""
        echo "Environment variables:"
        echo "  OUTPUT_DIR     Where to save components (default: ./.melo-output)"
        echo "  KEEP_TEMP      Keep temporary files (default: 0)"
        exit 1
    fi
    
    setup
    
    local prompt="$1"
    shift
    local files=("$@")
    
    # If files not provided, try to extract from prompt
    if [ ${#files[@]} -eq 0 ]; then
        log_info "No files specified, extracting from prompt..."
        mapfile -t files < <(extract_file_paths "$prompt")
    fi
    
    # Build context
    local context
    context=$(build_project_context "$prompt" "${files[@]}")
    
    # Generate with Bolt
    call_bolt "$prompt" "$context"
    
    # Wait for user to import Bolt code
    echo ""
    log_warn "📍 Next step: Import Bolt-generated code"
    echo "Once you have the code from Bolt, run:"
    echo "  melo --import-bolt <your-bolt-file.tsx>"
    echo ""
    echo "To continue the flow and refine with Codex."
    
    trap cleanup EXIT
}

# Handle import-bolt flag
if [ "$1" = "--import-bolt" ]; then
    setup
    
    if [ -z "$2" ]; then
        log_error "Usage: melo --import-bolt <file>"
        exit 1
    fi
    
    local bolt_file
    bolt_file=$(import_bolt_code "$2")
    
    # Check if we have context from previous run
    if [ -f "$TEMP_DIR/bolt-context.txt" ]; then
        log_info "Found previous context, refining with Codex..."
        
        local refined
        refined=$(refine_with_codex "$bolt_file" "$(cat "$TEMP_DIR/bolt-context.txt")" "")
        
        save_component "$refined" "RefinedComponent"
    else
        log_warn "No previous context found"
        log_info "Bolt code saved to: $bolt_file"
        cp "$bolt_file" "$OUTPUT_DIR/BoltGenerated.tsx"
        log_success "Component saved to: $OUTPUT_DIR/BoltGenerated.tsx"
    fi
    
    trap cleanup EXIT
    exit 0
fi

# Run main
main "$@"
trap cleanup EXIT
